{%- liquid
  assign menu_handle = section.settings.menu | default: 'main-menu'
  assign logo_image = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign logo_text = section.settings.logo_text
  assign sticky_header = section.settings.sticky_header
  assign show_search = section.settings.show_search
  assign show_cart = section.settings.show_cart
  assign show_wishlist = section.settings.show_wishlist
  assign show_profile = section.settings.show_profile
  assign support_url = section.settings.support_url | default: '/pages/support'
  assign color_bg = section.settings.color_bg
  assign color_text = section.settings.color_text
  assign color_icon = section.settings.color_icon
-%}

<style>
  #shopify-section-{{ section.id }} {
    --header-bg: {{ color_bg | default: '#FFFFFF' }};
    --header-text: {{ color_text | default: '#1A202C' }};
    --header-icon: {{ color_icon | default: '#1A202C' }};
  }
</style>

<header class="header" id="header-{{ section.id }}" data-section-id="{{ section.id }}" data-sticky="{{ sticky_header }}">
  <div class="container header-inner">
    <button class="mobile-toggle" id="mobileToggle" aria-label="{{ 'sections.header.mobile_toggle_label' | t }}" aria-controls="mobileMenu">
      <span class="hamburger-fallback" aria-hidden="true">&#9776;</span>
    </button>

    <a href="{{ routes.root_url }}" class="logo">
      {%- if logo_image != blank -%}
        {%- assign logo_width_2x = logo_width | times: 2 -%}
        <img
          src="{{ logo_image | image_url: width: logo_width }}"
          srcset="{{ logo_image | image_url: width: logo_width }} 1x, {{ logo_image | image_url: width: logo_width_2x }} 2x"
          alt="{{ shop.name }}"
          width="{{ logo_width }}"
          height="{{ logo_image.height | times: logo_width | divided_by: logo_image.width }}"
          style="max-width: {{ logo_width }}px;"
          loading="eager"
        >
      {%- else -%}
        {{ logo_text | default: shop.name }}
      {%- endif -%}
    </a>

    <nav>
      <ul class="nav-menu">
        {% if linklists[menu_handle].links.size > 0 %}
          {% for link in linklists[menu_handle].links %}
            <li class="nav-item">
              <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
              {% if link.links.size > 0 %}
                <ul class="dropdown">
                  {% for child_link in link.links %}
                    <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        {% else %}
          <li class="nav-item"><a href="{{ routes.all_products_collection_url }}" class="nav-link{% if request.page_type == 'collection' or request.page_type == 'product' %} active{% endif %}">{{ 'sections.header.shop_link' | t }}</a></li>
          <li class="nav-item"><a href="#brand-story" class="nav-link">{{ 'sections.header.about_link' | t }}</a></li>
          <li class="nav-item"><a href="{{ support_url }}" class="nav-link">{{ 'sections.header.support_link' | t }}</a></li>
        {% endif %}
      </ul>
    </nav>

    <div class="header-icons">
      {% if show_search %}
        <button class="icon-btn" id="searchTrigger" aria-label="{{ 'sections.header.search_label' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
      {% endif %}

      {% if show_wishlist %}
        <button class="icon-btn mobile-wishlist-icon" title="{{ 'sections.header.wishlist_title' | t }}" aria-label="{{ 'sections.header.wishlist_label' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span class="wishlist-count" aria-live="polite" aria-atomic="true">0</span>
        </button>
      {% endif %}

      {% if show_profile %}
        <div class="icon-btn profile-dropdown" role="button" tabindex="0" aria-haspopup="true" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <ul class="profile-menu">
            {% if customer %}
              <li><a href="{{ routes.account_url }}">{{ 'sections.header.account_link' | t }}</a></li>
              <li><a href="{{ routes.account_logout_url }}">{{ 'sections.header.logout_link' | t }}</a></li>
            {% else %}
              <li><a href="{{ routes.account_login_url }}">{{ 'sections.header.login_link' | t }}</a></li>
              <li><a href="{{ routes.account_register_url }}">{{ 'sections.header.register_link' | t }}</a></li>
            {% endif %}
            <li class="divider profile-card-mobile"></li>
            <li class="profile-card-mobile"><a href="#" id="profileCardLink">{{ 'sections.header.cart_link' | t }}</a></li>
          </ul>
        </div>
      {% endif %}

      {% if show_wishlist %}
        <button class="icon-btn wishlist-icon" title="{{ 'sections.header.wishlist_title' | t }}" aria-label="{{ 'sections.header.wishlist_label' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span class="wishlist-count" aria-live="polite" aria-atomic="true">0</span>
        </button>
      {% endif %}

      {% if show_cart %}
        <div class="icon-btn cart-icon-btn" title="{{ 'sections.header.cart_title' | t }}" role="button" tabindex="0" aria-label="{{ 'sections.header.cart_label' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="cart-count" aria-live="polite" aria-atomic="true">{{ cart.item_count }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</header>

<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "section",
  "class": "section-header",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.header.settings.logo_header.content"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.settings.logo_image.label"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "t:sections.header.settings.logo_width.label",
      "default": 150
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:sections.header.settings.logo_text.label",
      "default": "Amaanix"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.colors_header.content"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "t:sections.header.settings.color_bg.label",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "t:sections.header.settings.color_text.label",
      "default": "#1A202C"
    },
    {
      "type": "color",
      "id": "color_icon",
      "label": "t:sections.header.settings.color_icon.label",
      "default": "#1A202C"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.navigation_header.content"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.layout_header.content"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "t:sections.header.settings.sticky_header.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.icons_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.header.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "t:sections.header.settings.show_wishlist.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "t:sections.header.settings.show_cart.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_profile",
      "label": "t:sections.header.settings.show_profile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.support_header.content"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "t:sections.header.settings.support_url.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.header.presets.name"
    }
  ]
}
{% endschema %}
