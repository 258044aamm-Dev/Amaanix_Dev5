{{ 'section-brand-story.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="brand-story section-{{ section.id }}-padding" id="brand-story-{{ section.id }}">
  <div id="brand-story"></div>
  <div class="container">
    <div class="story-grid">
      <div class="story-image">
        {%- if section.settings.image != blank -%}
          <img
            loading="lazy"
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          <img
            loading="lazy"
            src="{{ 'brand-story-hero.png' | asset_url }}"
            alt="Brand Story"
            width="1200"
            height="600"
          >
        {%- endif -%}
      </div>
      <div class="story-content">
        {%- if section.settings.subheading != blank -%}
          <h4>{{ section.settings.subheading }}</h4>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.content != blank -%}
          <div class="story-text-content">
            {{ section.settings.content }}
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="btn-primary"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Brand image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "default": "About Amaanix",
      "label": "Subheading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Built on Trust. Driven by Discipline.",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "content",
      "default": "<p>Amaanix is built to make online shopping <strong style=\"color: #00B5B8;\">simple</strong>, <strong style=\"font-weight: 600;\">seamless</strong>, and <strong style=\"color: #00B5B8;\">reliable</strong>.</p><p>We focus on delivering thoughtfully selected products with a strong commitment to <strong style=\"color: #014C52;\">quality and trust</strong>.</p><p>In a short time, we've earned the confidence of <strong style=\"font-weight: 600;\">thousands of customers</strong> across the United States by keeping everything clear, consistent, and customer-first.</p><p>&ldquo;Amaanix understands what you need&mdash;and delivers it with care.&rdquo;</p>",
      "label": "Content (HTML)"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "SHOP NOW",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}