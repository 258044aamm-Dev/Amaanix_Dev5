{{ 'section-deals-countdown.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- style -%}
  {% if section.settings.button_border_radius > 0 -%}
    #deals-section-{{ section.id }} .button {
      border-radius: {{ section.settings.button_border_radius }}px;
    }
  {%- endif %}
  #deals-section-{{ section.id }} .button[aria-disabled="true"],
  #deals-section-{{ section.id }} .button:disabled {
    opacity: 1;
    cursor: pointer;
  }
  #deals-section-{{ section.id }} {
    --color-foreground: 255, 255, 255;
    --color-secondary-button: 255, 255, 255;
    --color-secondary-button-text: 255, 255, 255;
  }
  #deals-section-{{ section.id }} .button--secondary {
    --alpha-button-background: 0;
  }
  #deals-section-{{ section.id }} .button--primary {
    --color-button: 0, 181, 184;
    --color-button-text: 255, 255, 255;
    transition: transform 0.3s ease, box-shadow var(--duration-short) ease;
  }
  #deals-section-{{ section.id }} .button--primary:not([disabled]):hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 181, 184, 0.35);
  }
{%- endstyle -%}

{%- liquid
  assign btn_class = 'button'
  if section.settings.button_style == 'outline'
    assign btn_class = btn_class | append: ' button--secondary'
  else
    assign btn_class = btn_class | append: ' button--primary'
  endif
  if section.settings.button_size == 'small'
    assign btn_class = btn_class | append: ' button--small'
  endif
  if section.settings.button_full_width
    assign btn_class = btn_class | append: ' button--full-width'
  endif
-%}

<div class="gradient color-{{ section.settings.color_scheme }}">
  <div class="deals-section section-{{ section.id }}-padding" id="deals-section-{{ section.id }}">
    <div class="container">
      <div class="deals-grid">
        <div class="deals-image">
          {%- if section.settings.image != blank -%}
            <img
              loading="lazy"
              src="{{ section.settings.image | image_url: width: 1200 }}"
              alt="{{ section.settings.image.alt | escape }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          {%- else -%}
            <img
              loading="lazy"
              src="{{ 'deal-product-featured.png' | asset_url }}"
              alt="Deal Product"
              width="1200"
              height="600"
            >
          {%- endif -%}
        </div>
        <div class="deals-content">
          <h2>{{ section.settings.heading }}</h2>
          <h3 class="deals-product-title">{{ section.settings.product_title | escape }}</h3>
          <div class="deals-price">
            {%- if section.settings.old_price != blank -%}
              <span class="deals-old-price">{{ section.settings.old_price | escape }}</span>
            {%- endif -%}
            {{ section.settings.new_price | escape }}
          </div>
          <p>{{ section.settings.description | escape }}</p>
          <div
            class="countdown"
            id="countdown-{{ section.id }}"
            data-section-id="{{ section.id }}"
            data-countdown-days="{{ section.settings.countdown_days }}"
            data-countdown-hours="{{ section.settings.countdown_hours }}"
          >
            <div class="countdown-item">
              <div class="countdown-number" id="days-{{ section.id }}">02</div>
              <div class="countdown-label">Days</div>
            </div>
            <div class="countdown-item">
              <div class="countdown-number" id="hours-{{ section.id }}">14</div>
              <div class="countdown-label">Hours</div>
            </div>
            <div class="countdown-item">
              <div class="countdown-number" id="minutes-{{ section.id }}">33</div>
              <div class="countdown-label">Mins</div>
            </div>
            <div class="countdown-item">
              <div class="countdown-number" id="seconds-{{ section.id }}">07</div>
              <div class="countdown-label">Secs</div>
            </div>
          </div>
          {%- if section.settings.button_label != blank -%}
            <a
              {% if section.settings.button_link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ section.settings.button_link }}"
              {% endif %}
              class="{{ btn_class | escape }}"
            >
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var countdownEl = document.getElementById('countdown-{{ section.id }}');
  if (!countdownEl) return;

  var sectionId = '{{ section.id }}';
  var daysEl = document.getElementById('days-' + sectionId);
  var hoursEl = document.getElementById('hours-' + sectionId);
  var minutesEl = document.getElementById('minutes-' + sectionId);
  var secondsEl = document.getElementById('seconds-' + sectionId);
  if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return;

  var configuredDays = parseInt(countdownEl.getAttribute('data-countdown-days'), 10) || 2;
  var configuredHours = parseInt(countdownEl.getAttribute('data-countdown-hours'), 10) || 14;

  var storageKey = 'amaanix_deal_end_' + sectionId;
  var dealEnd = localStorage.getItem(storageKey);
  if (!dealEnd) {
    var now = new Date();
    var end = new Date(now.getTime() + (configuredDays * 24 * 60 * 60 * 1000) + (configuredHours * 60 * 60 * 1000));
    dealEnd = end.getTime().toString();
    localStorage.setItem(storageKey, dealEnd);
  }

  function updateCountdown() {
    var now = new Date().getTime();
    var distance = parseInt(dealEnd, 10) - now;

    if (distance <= 0) {
      daysEl.textContent = '00';
      hoursEl.textContent = '00';
      minutesEl.textContent = '00';
      secondsEl.textContent = '00';
      return;
    }

    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

    daysEl.textContent = String(days).padStart(2, '0');
    hoursEl.textContent = String(hours).padStart(2, '0');
    minutesEl.textContent = String(minutes).padStart(2, '0');
    secondsEl.textContent = String(seconds).padStart(2, '0');
  }

  updateCountdown();
  var intervalId = setInterval(updateCountdown, 1000);

  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:unload', function(event) {
      if (event.detail && event.detail.sectionId === sectionId) {
        clearInterval(intervalId);
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Deals Countdown",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "🔥 DEAL OF THE WEEK",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "product_title",
      "default": "Smart Home Speaker",
      "label": "Product title"
    },
    {
      "type": "text",
      "id": "old_price",
      "default": "$99.00",
      "label": "Old price (strikethrough)"
    },
    {
      "type": "text",
      "id": "new_price",
      "default": "$59.00",
      "label": "Sale price"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Voice-controlled assistant with premium sound quality. Limited stock available.",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "GRAB THE DEAL",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "Primary (filled)"
        },
        {
          "value": "outline",
          "label": "Outline (transparent)"
        }
      ],
      "default": "primary",
      "label": "Button style"
    },
    {
      "type": "select",
      "id": "button_size",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "small",
          "label": "Small"
        }
      ],
      "default": "default",
      "label": "Button size"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 0,
      "unit": "px",
      "label": "Button border radius"
    },
    {
      "type": "checkbox",
      "id": "button_full_width",
      "default": false,
      "label": "Full width button"
    },
    {
      "type": "header",
      "content": "Countdown"
    },
    {
      "type": "range",
      "id": "countdown_days",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 2,
      "label": "Countdown days"
    },
    {
      "type": "range",
      "id": "countdown_hours",
      "min": 0,
      "max": 23,
      "step": 1,
      "default": 14,
      "label": "Countdown hours"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Deals Countdown"
    }
  ]
}
{% endschema %}
