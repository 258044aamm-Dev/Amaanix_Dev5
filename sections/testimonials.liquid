{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding" id="testimonials-section-{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="testimonials-header">
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-stars" aria-label="{{ block.settings.stars }} out of 5 stars">
            {%- if block.settings.stars == '4.5' -%}
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star-half-alt" aria-hidden="true"></i>
            {%- else -%}
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
            {%- endif -%}
          </div>
          <p class="testimonial-text">{{ block.settings.quote }}</p>
          <div class="testimonial-author">
            {%- if block.settings.avatar != blank -%}
              <img loading="lazy" src="{{ block.settings.avatar | image_url: width: 120 }}" alt="{{ block.settings.author_name | escape }}" class="author-avatar" width="60" height="60">
            {%- else -%}
              <img loading="lazy" src="{{ 'avatar-sarah-jenkins.png' | asset_url }}" alt="{{ block.settings.author_name | escape }}" class="author-avatar" width="60" height="60">
            {%- endif -%}
            <div class="author-info">
              <h5>{{ block.settings.author_name }}</h5>
              <div class="verified-badge"><i class="fas fa-check-circle" aria-hidden="true"></i> {{ block.settings.verified_label }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.getElementById('testimonials-section-{{ section.id }}');
  if (!section) return;
  var cards = section.querySelectorAll('.testimonial-card');
  if (cards.length === 0) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    cards.forEach(function(card) { observer.observe(card); });
  } else {
    cards.forEach(function(c) { c.classList.add('visible'); });
  }
})();
</script>

{% schema %}
{
  "name": "Testimonials",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "WHAT OUR CUSTOMERS SAY",
      "label": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "default": "Real experiences from real people \u2014 trust speaks for itself",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "select",
          "id": "stars",
          "label": "Star rating",
          "options": [
            { "value": "5", "label": "5 stars" },
            { "value": "4.5", "label": "4.5 stars" }
          ],
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "quote",
          "default": "\"The quality of products from Amaanix is unmatched. I've redecorated my entire home office with their items and couldn't be happier.\"",
          "label": "Quote"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author avatar"
        },
        {
          "type": "text",
          "id": "verified_label",
          "default": "Verified Buyer",
          "label": "Verified badge label"
        },
        {
          "type": "text",
          "id": "author_name",
          "default": "Sarah Jenkins",
          "label": "Author name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "stars": "5",
            "quote": "\"The quality of products from Amaanix is unmatched. I've redecorated my entire home office with their items and couldn't be happier.\"",
            "verified_label": "Verified Buyer",
            "author_name": "Sarah Jenkins"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": "5",
            "quote": "\"Fast shipping and excellent customer service. The eco-friendly products are exactly what I was looking for. Highly recommend!\"",
            "verified_label": "Verified Buyer",
            "author_name": "Michael Chen"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": "4.5",
            "quote": "\"Love the aesthetic and functionality. The kitchen tools are beautiful and durable. Will definitely be shopping here again.\"",
            "verified_label": "Verified Buyer",
            "author_name": "Emily Rodriguez"
          }
        }
      ]
    }
  ]
}
{% endschema %}